# ── Feature flag ──────────────────────────────────────────────────────────────
# Imposta a "true" per attivare la pipeline Instagram
INSTAGRAM_ENABLED=false

# ── Instagram (instagrapi) ────────────────────────────────────────────────────
INSTAGRAM_USERNAME=foxscan_ig
INSTAGRAM_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
UNSPLASH_ACCESS_KEY=...

# ── Database (stesso del backend Foxscan) ────────────────────────────────────
# PostgreSQL su Neon/Render:
DATABASE_URL=postgresql://user:pass@host/dbname
# Oppure SQLite locale per test:
# DATABASE_URL=sqlite:///C:/me/Progetti Personali/Foxscan/backend/cybernews.db
